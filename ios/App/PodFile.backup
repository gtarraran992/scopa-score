require_relative '../../node_modules/@capacitor/ios/scripts/pods_helpers'

platform :ios, '14.0'
use_frameworks!

install! 'cocoapods', :disable_input_output_paths => true

def capacitor_pods
 pod 'Capacitor', :path => '/Users/builder/clone/node_modules/@capacitor/ios'
 pod 'CapacitorApp', :path => '/Users/builder/clone/node_modules/@capacitor/app'
 pod 'CapacitorFirebaseAuthentication', :path => '/Users/builder/clone/node_modules/@capacitor-firebase/authentication'
 pod 'CapacitorCamera', :path => '/Users/builder/clone/node_modules/@capacitor/camera'
 pod 'CapacitorLocalNotifications', :path => '/Users/builder/clone/node_modules/@capacitor/local-notifications'
 pod 'CapacitorPushNotifications', :path => '/Users/builder/clone/node_modules/@capacitor/push-notifications'
 pod 'CapacitorBrowser', :path => '/Users/builder/clone/node_modules/@capacitor/browser'
 pod 'CapacitorCommunityNativeAudio', :path => '/Users/builder/clone/node_modules/@capacitor-community/native-audio'
end

target 'App' do
  capacitor_pods
end